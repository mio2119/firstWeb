{
  "name": "慧招启涯",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/run-vite-build.mjs",
    "preview": "vite preview",
    "backend:dev": "node backend/node_server.mjs",
    "backend:dev:fastapi": "python -m uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8000",
    "check": "npm run workbench:verify",
    "check:data": "node scripts/validate-data.mjs",
    "check:types": "tsc --noEmit",
    "check:backend": "python -m compileall -q backend && node --check backend/node_server.mjs",
    "workbench:manifest": "node scripts/workbench-manifest.mjs --write",
    "workbench:verify": "node scripts/workbench-verify.mjs",
    "workbench:loop": "node scripts/workbench-loop.mjs"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.10.1",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.561.0",
    "gsap": "^3.14.2",
    "chart.js": "^4.4.1",
    "react-chartjs-2": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
